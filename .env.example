COMPOSE_PROJECT_NAME=ghostfolio

# CACHE
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<INSERT_REDIS_PASSWORD>

# POSTGRES
POSTGRES_DB=ghostfolio-db
POSTGRES_USER=user
POSTGRES_PASSWORD=<INSERT_POSTGRES_PASSWORD>

# VARIOUS
ACCESS_TOKEN_SALT=<INSERT_RANDOM_STRING>
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?connect_timeout=300&sslmode=prefer
JWT_SECRET_KEY=<INSERT_RANDOM_STRING>

# ── AI Agent (AgentForge) ──────────────────────────────────────────────────
# OpenAI
OPENAI_API_KEY=<INSERT_OPENAI_API_KEY>
OPENAI_MODEL=gpt-4.1

# Langfuse — agent tracing, eval datasets, user feedback scores
# Sign up free at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=<INSERT_LANGFUSE_PUBLIC_KEY>
LANGFUSE_SECRET_KEY=<INSERT_LANGFUSE_SECRET_KEY>
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Helicone — proxy-based LLM cost + latency dashboard (optional)
# Sign up free at https://helicone.ai
# When set, all OpenAI calls route through oai.hconeai.com automatically
HELICONE_API_KEY=<INSERT_HELICONE_API_KEY>
