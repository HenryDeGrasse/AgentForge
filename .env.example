COMPOSE_PROJECT_NAME=ghostfolio

# CACHE
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<INSERT_REDIS_PASSWORD>

# POSTGRES
POSTGRES_DB=ghostfolio-db
POSTGRES_USER=user
POSTGRES_PASSWORD=<INSERT_POSTGRES_PASSWORD>

# VARIOUS
ACCESS_TOKEN_SALT=<INSERT_RANDOM_STRING>
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?connect_timeout=300&sslmode=prefer
JWT_SECRET_KEY=<INSERT_RANDOM_STRING>

# ── AI Agent (AgentForge) ──────────────────────────────────────────────────
# Copy these into your local .env (never commit .env — it is gitignored).
#
# Required:
#   OPENAI_API_KEY   — get from https://platform.openai.com/account/api-keys
#   OPENAI_MODEL     — e.g. gpt-4.1-mini (default) or gpt-4.1
#
# Optional — observability (leave unset to disable):
#   LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY — https://cloud.langfuse.com
#   LANGFUSE_BASE_URL                         — https://cloud.langfuse.com
#   HELICONE_API_KEY                          — https://helicone.ai
#
# NOTE: values are intentionally blank here so that `dotenv-cli -e .env.example`
# in CI does not inject placeholder strings that break tests.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
HELICONE_API_KEY=
