  {
    "id": "rich-holdings-summary",
    "profile": "rich",
    "liveEligible": true,
    "request": {
      "message": "What are my top holdings and total portfolio value?",
      "toolNames": ["get_portfolio_summary"]
    },
    "expect": {
      "status": "completed",
      "minConfidence": "high",
      "minToolCalls": 1,
      "maxToolCalls": 2,
      "requiredTools": ["get_portfolio_summary"],
      "mustIncludeAny": [
        "portfolio",
        "holding",
        "value",
        "VOO",
        "NVDA",
        "AAPL"
      ],
      "mustContainAll": ["$"],
      "mustNotIncludeAny": [
        "technical issue",
        "unable to access",
        "undefined",
        "NaN",
        "[object Object]"
      ],
      "dataValueChecks": [
        {
          "label": "holdingsCount",
          "valueInResponse": "10"
        },
        {
          "label": "totalValue",
          "valueInResponse": "55"
        }
      ],
      "toolEnvelopeChecks": [
        {
          "toolName": "get_portfolio_summary",
          "expectStatus": "success",
          "dataFieldsPresent": ["topHoldings", "totals"]
        }
      ]
    },
    "meta": {
      "stage": "golden",
      "category": "single-tool",
      "subcategory": "portfolio-summary",
      "difficulty": "basic",
      "description": "Basic portfolio summary — must mention specific holdings and total value",
      "addedFrom": "initial"
    }
  },
